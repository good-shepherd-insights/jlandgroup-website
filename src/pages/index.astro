        "name": "BBB Accredited Business"
      }
    ]
  },
  // BreadcrumbList Schema
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://jlandgroup.com"
      }
    ]
  },
  // SiteNavigationElement Schema
  {
    "@context": "https://schema.org",
    "@type": "SiteNavigationElement",
    "name": "Home",
    "url": "https://jlandgroup.com"
  },
  {
    "@context": "https://schema.org",
    "@type": "SiteNavigationElement",
    "name": "About",
    "url": "https://jlandgroup.com/about"
  },
  {
    "@context": "https://schema.org",
    "@type": "SiteNavigationElement",
    "name": "Services",
    "url": "https://jlandgroup.com/services"
  },
  {
    "@context": "https://schema.org",
    "@type": "SiteNavigationElement",
    "name": "Appointment",
    "url": "https://jlandgroup.com/appointment"
  },
  {
    "@context": "https://schema.org",
    "@type": "SiteNavigationElement",
    "name": "Contact",
    "url": "https://jlandgroup.com/contact"
  },
  {
    "@context": "https://schema.org",
    "@type": "SiteNavigationElement",
    "name": "Blog",
    "url": "https://jlandgroup.com/blog"
  },
  // Video Schema for Facebook Video
  {
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": "Roofing Services by J Land Contracting",
    "description": "Watch our roofing services and customer testimonials. Professional roof replacement, repairs, and inspections in the DMV area.",
    "thumbnailUrl": "https://jlandgroup.com/images/og-image.png",
    "uploadDate": "2024-01-15",
    "duration": "PT2M30S",
    "contentUrl": "https://www.facebook.com/watch?v=531150551239056",
    "embedUrl": "https://www.facebook.com/plugins/video.php?href=https%3A%2F%2Fwww.facebook.com%2Fwatch%3Fv%3D531150551239056",
    "author": {
      "@type": "Organization",
      "name": "J Land Contracting"
    },
    "publisher": {
      "@type": "Organization",
      "name": "J Land Contracting"
    }
  }
];

---

<Base schemaData={schemaData}>
  <HeroBanner />
  <Partners />
  <WhyChooseUs data={why_choose_us} />
  <WhatWeOffer />
  <OurExpertise />
  <CallToAction />
  <Testimonial />

  {
    blog_section.enable && (
      <section class="section">
        <div class="container">
          <h2
            
            
            class="h2 text-center"
            set:html={markdownify(blog_section.title)}
          />
          <p
            
            
            class="text-lg mt-6 mb-12 max-w-[80%] mx-auto text-center text-balance"
            set:html={markdownify(blog_section.description)}
          />
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            {featuredBlogs.map((blog) => (
              <BlogCard data={blog} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <FAQs />
</Base>
