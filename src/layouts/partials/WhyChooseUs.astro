---
import ImageMod from "@/components/ImageMod.astro";
import FacebookVideo from "../components/FacebookVideo.astro";
import { markdownify } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";
import { FaCheck } from "react-icons/fa6";

type Props = {
  data: CollectionEntry<"aboutpage">["data"]["why_choose_us"];
  backgroundColor?: string;
};

const { data, backgroundColor = "bg-light" } = Astro.props;
if (!data.enable) return null;
---

<section class={`section ${backgroundColor}`}>
  <div class="container px-6 flex max-lg:flex-col gap-16 items-center">
    <div class="lg:w-[50%] flex flex-col items-center gap-8">
      {/* Social Interaction Stats */}
      <div class="flex items-center gap-8 text-secondary font-bold text-lg">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-auto text-[#1877F2]" fill="currentColor" viewBox="0 0 16 16">
            <path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951"/>
          </svg>
        </div>
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-auto" viewBox="0 0 64 64" fill="currentColor">
            <path d="M64 29.138c0-2.6-2.9-3.8-3.8-3.8H40.6s1.9-8.3 2-11.2-2.8-9.1-3.4-9.6-3.7-1.1-5.1.5c.1 2.2.4 9 .4 9s-4.6 8.2-7.2 12.3a21.36 21.36 0 0 1-6 6.1v20.7h1.8c.6 0 2.9 2.1 4.6 2.1h24.4c2.1 0 5.6-.2 5.6-3.6a3.286 3.286 0 0 0-1.4-2.8v-.4s3.4-1.1 3.4-4.1a3.006 3.006 0 0 0-1.4-2.5l.2-.8s3.2-1.2 3.2-4.2c0-1.9-1.3-2.2-1.3-2.2l.2-.9c.2-.2 3.4-1.5 3.4-4.6zm-49.1.5H3.2a3.159 3.159 0 0 0-3.2 3.2l2.1 21.3a3.159 3.159 0 0 0 3.2 3.2h9.6a3.159 3.159 0 0 0 3.2-3.2v-21.3a3.222 3.222 0 0 0-3.2-3.2z"/>
          </svg>
          <span>1.5K</span>
        </div>
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-auto" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
          <span>205</span>
        </div>
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-auto" fill="currentColor" viewBox="0 0 16 16">
            <path d="M13.5 1a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3M11 2.5a2.5 2.5 0 0 1 .603 1.628l-6.718 3.12a2.5 2.5 0 0 1 0 1.504l6.718 3.12a2.5 2.5 0 1 1-.488.876l-6.718-3.12a2.5 2.5 0 0 1 0-3.256l6.718-3.12A2.5 2.5 0 0 1 11 2.5m-8.5 4a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3m11 5.5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3"/>
          </svg>
          <span>1K</span>
        </div>
      </div>

      <FacebookVideo 
        videoUrl="https://www.facebook.com/reel/531150551239056"
        thumbnail="/images/daniel-nam-frederick-roofing-jland-contracting.png"
        description="Experience the JLand difference — click to load the video"
      />
      
      <div class="bg-secondary px-8 py-6 rounded-3xl shadow-xl shadow-secondary/10 border-2 border-white/10">
        <ImageMod
          src="/images/badges/howard-county-maryland.png"
          class="h-14 w-auto object-contain"
          alt="Howard County Maryland"
          width={208}
          height={59}
        />
      </div>
    </div>
    <div class="lg:w-[50%]">
      <h2 class="text-h1" set:html={markdownify(data.title)} />
      <p class="text-lg mt-6" set:html={markdownify(data.description)} />

      <div class="mt-8 space-y-6">
        {
          data.features.map((feature, i) => (
            <div
              data-aos-delay={`${100 + i * 100}`}
              class="flex gap-4 items-start"
            >
              <FaCheck className="text-primary mt-1 shrink-0" size={16} />
              <p class="text-lg text-balance" set:html={markdownify(feature)} />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
