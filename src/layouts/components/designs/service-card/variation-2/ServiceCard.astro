---
import ImageMod from "@/components/ImageMod.astro";
import { markdownify } from "@/lib/utils/textConverter";

const { data, id } = Astro.props;
---

<div
  class="relative flex flex-col h-full bg-white rounded-3xl overflow-hidden border border-border shadow-sm"
>
  {/* Professional Service Image */}
  <div class="relative h-60 overflow-hidden">
    {
      data.image && (
        <ImageMod
          src={data.image}
          alt={data.title}
          width={800}
          height={500}
          class="w-full h-full object-cover"
        />
      )
    }
  </div>

  {/* Structured Content Area */}
  <div class="p-8 flex flex-col grow">
    <h3
      class="text-2xl font-bold mb-3 text-text-dark leading-tight"
      set:html={markdownify(data.title)}
    />
    
    <p
      class="mb-8 grow text-text text-sm leading-relaxed"
      set:html={markdownify(data.description)}
    />

    {/* Direct CTA */}
    <a
      href={id ? `/services/${id}` : "#"}
      class="flex items-center justify-center gap-2 w-full py-4 bg-primary text-dark rounded-xl font-black uppercase tracking-widest text-[11px] transition-none"
    >
      {data.contact_form?.button_label || "View Service"}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-4 h-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2.5"
          d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
      </svg>
    </a>
  </div>
</div>

