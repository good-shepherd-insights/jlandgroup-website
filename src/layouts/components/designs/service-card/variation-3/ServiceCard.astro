---
import ImageMod from "@/components/ImageMod.astro";
import { markdownify } from "@/lib/utils/textConverter";

const { data, id } = Astro.props;
---

<div
  class="relative flex flex-col h-full bg-light rounded-2xl overflow-hidden border border-border"
>
  {/* Premium Minimalist Image */}
  <div class="relative h-72 overflow-hidden">
    {
      data.image && (
        <ImageMod
          src={data.image}
          alt={data.title}
          width={800}
          height={600}
          class="w-full h-full object-cover"
        />
      )
    }
  </div>

  {/* Minimalist Content Area */}
  <div class="p-10 flex flex-col grow">
    <div class="flex items-center justify-between mb-6">
      <h3
        class="text-3xl font-bold text-text-dark tracking-tight"
        set:html={markdownify(data.title)}
      />
      {
        data.icon && (
          <ImageMod
            src={data.icon}
            alt="icon"
            width={24}
            height={24}
            class="w-6 h-6 opacity-60"
          />
        )
      }
    </div>

    <p
      class="mb-10 grow text-text text-base leading-relaxed"
      set:html={markdownify(data.description)}
    />

    {/* Primary Brand CTA */}
    <a
      href={id ? `/services/${id}` : "#"}
      class="flex items-center justify-center gap-3 w-full py-5 bg-primary text-dark rounded-full font-black uppercase tracking-widest text-xs transition-none"
    >
      {data.contact_form?.button_label || "View Service Details"}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-4 h-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="3"
          d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
      </svg>
    </a>
  </div>
</div>

