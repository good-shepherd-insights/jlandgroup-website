---
import { markdownify } from "@/lib/utils/textConverter";

interface Props {
  challenges_title?: string;
  challenges_body?: string;
  service_area_title?: string;
  service_area_intro?: string;
  service_area_neighborhoods?: { name: string; slug?: string }[];
  city?: string;
  state?: string;
  county?: string;
}

const {
  challenges_title,
  challenges_body,
  service_area_title,
  service_area_intro,
  service_area_neighborhoods,
  city,
  state,
  county,
} = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="text-center max-w-3xl mx-auto mb-12">
      {city && state && (
        <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-2">{city}, {state}</p>
      )}
      {county && (
        <p class="text-sm text-text/60 mb-4">{county}</p>
      )}
      <div class="space-y-4">
        <slot />
      </div>
    </div>

    {challenges_title && challenges_body && (
      <div class="relative mb-12 rounded-2xl overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-r from-primary to-primary/80" />
        <div class="absolute top-4 left-6 text-[8rem] leading-none font-black text-white/10 select-none pointer-events-none" aria-hidden="true">&ldquo;</div>
        <div class="relative p-8 md:p-10 md:flex md:items-start md:gap-10">
          <h3 class="h3 mb-3 md:mb-0 md:w-1/3 md:shrink-0 text-text-light" set:html={markdownify(challenges_title)} />
          <p class="md:w-2/3 text-balance text-text-light/90 leading-relaxed" set:html={markdownify(challenges_body)} />
        </div>
      </div>
    )}

    {service_area_title && service_area_neighborhoods && service_area_neighborhoods.length > 0 && (
      <div>
        <h3 class="h3 mb-2 text-center" set:html={markdownify(service_area_title)} />
        {service_area_intro && (
          <p class="mb-8 max-w-2xl mx-auto text-center" set:html={markdownify(service_area_intro)} />
        )}
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
          {service_area_neighborhoods.map((area, i) => (
            area.slug ? (
              <a
                href={`/locations/${area.slug}`}
                class="group relative flex items-center gap-2 p-3 rounded-xl bg-light hover:bg-primary transition-colors duration-200"
              >
                <span class="flex items-center justify-center w-6 h-6 rounded-full bg-primary/15 text-primary text-xs font-bold group-hover:bg-dark group-hover:text-primary transition-colors duration-200">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span class="text-sm font-medium text-text group-hover:text-dark transition-colors duration-200">
                  {area.name}
                </span>
              </a>
            ) : (
              <div class="flex items-center gap-2 p-3 rounded-xl bg-light">
                <span class="flex items-center justify-center w-6 h-6 rounded-full bg-border text-text/40 text-xs font-bold">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span class="text-sm font-medium text-text/50">
                  {area.name}
                </span>
              </div>
            )
          ))}
        </div>
      </div>
    )}
  </div>
</section>