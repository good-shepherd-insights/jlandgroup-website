---
import { markdownify } from "@/lib/utils/textConverter";

interface Props {
  challenges_title?: string;
  challenges_body?: string;
  service_area_title?: string;
  service_area_intro?: string;
  service_area_neighborhoods?: { name: string; slug?: string }[];
  city?: string;
  state?: string;
  county?: string;
}

const {
  challenges_title,
  challenges_body,
  service_area_title,
  service_area_intro,
  service_area_neighborhoods,
  city,
  state,
  county,
} = Astro.props;
---

<section class="section">
  <div class="container max-w-4xl mx-auto">
    <div class="text-center mb-12">
      {city && state && (
        <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-2">{city}, {state}</p>
      )}
      {county && (
        <p class="text-sm text-text/60 mb-4">{county}</p>
      )}
      <div class="space-y-4">
        <slot />
      </div>
    </div>

    <div class="space-y-0">
      {challenges_title && challenges_body && (
        <div class="relative pl-8 md:pl-10 py-8 border-l-2 border-border">
          <div class="absolute left-0 top-8 -translate-x-1/2 flex items-center justify-center w-8 h-8 rounded-full bg-primary text-dark text-sm font-bold shadow-sm">
            !
          </div>
          <h3 class="h3 mb-3" set:html={markdownify(challenges_title)} />
          <p class="text-balance leading-relaxed" set:html={markdownify(challenges_body)} />
        </div>
      )}

      {service_area_title && service_area_neighborhoods && service_area_neighborhoods.length > 0 && (
        <div class="relative pl-8 md:pl-10 py-8 border-l-2 border-border">
          <div class="absolute left-0 top-8 -translate-x-1/2 flex items-center justify-center w-8 h-8 rounded-full bg-primary text-dark text-sm shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
              <path fill-rule="evenodd" d="m9.69 18.933.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 00.281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 103 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 002.274 1.765 11.307 11.307 0 00.757.433c.12.062.218.11.281.14l.018.008.006.003zM10 11.25a2.25 2.25 0 100-4.5 2.25 2.25 0 000 4.5z" clip-rule="evenodd" />
            </svg>
          </div>
          <h3 class="h3 mb-2" set:html={markdownify(service_area_title)} />
          {service_area_intro && (
            <p class="mb-6 leading-relaxed" set:html={markdownify(service_area_intro)} />
          )}
          <div class="flex flex-wrap gap-x-2 gap-y-1">
            {service_area_neighborhoods.map((area, i) => (
              <>
                {area.slug ? (
                  <a
                    href={`/locations/${area.slug}`}
                    class="text-sm font-medium text-text hover:text-primary hover:underline underline-offset-4 decoration-primary/40 transition-colors duration-200"
                  >
                    {area.name}
                  </a>
                ) : (
                  <span class="text-sm text-text/40">
                    {area.name}
                  </span>
                )}
                {i < service_area_neighborhoods.length - 1 && (
                  <span class="text-border text-sm select-none" aria-hidden="true">&middot;</span>
                )}
              </>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</section>