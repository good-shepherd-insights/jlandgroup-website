---
import { markdownify } from "@/lib/utils/textConverter";

interface Props {
  body?: string;
  challenges_title?: string;
  challenges_body?: string;
  service_area_title?: string;
  service_area_intro?: string;
  service_area_neighborhoods?: { name: string; slug?: string }[];
  city?: string;
}

const {
  body,
  challenges_title,
  challenges_body,
  service_area_title,
  service_area_intro,
  service_area_neighborhoods,
  city,
} = Astro.props;
---

{body && (
  <div class="space-y-4" set:html={markdownify(body)} />
)}

{challenges_title && challenges_body && (
  <div class="relative mt-10 border-l-4 border-primary pl-6 md:pl-8 py-4 bg-gradient-to-r from-primary/5 to-transparent rounded-r-2xl">
    <span class="absolute -left-3 top-4 flex items-center justify-center w-6 h-6 rounded-full bg-primary text-dark text-xs font-bold">!</span>
    <h3 class="h3 mb-3" set:html={markdownify(challenges_title)} />
    <p class="text-balance max-w-3xl leading-relaxed" set:html={markdownify(challenges_body)} />
  </div>
)}

{service_area_title && service_area_neighborhoods && service_area_neighborhoods.length > 0 && (
  <div class="mt-10">
    <div class="flex items-center gap-4 mb-6">
      <div class="h-px flex-1 bg-border" />
      <h3 class="h3 whitespace-nowrap" set:html={markdownify(service_area_title)} />
      <div class="h-px flex-1 bg-border" />
    </div>
    {service_area_intro && (
      <p class="mb-8 max-w-2xl mx-auto text-center" set:html={markdownify(service_area_intro)} />
    )}
    <div class="flex flex-wrap justify-center gap-x-1 gap-y-1">
      {service_area_neighborhoods.map((area, i) => (
        <>
          {area.slug ? (
            <a
              href={`/locations/${area.slug}`}
              class="px-3 py-1 text-sm font-medium text-text hover:text-primary hover:bg-primary/10 rounded transition-colors duration-200"
            >
              {area.name}
            </a>
          ) : (
            <span class="px-3 py-1 text-sm text-text/40">
              {area.name}
            </span>
          )}
          {i < service_area_neighborhoods.length - 1 && (
            <span class="text-border text-sm select-none" aria-hidden="true">&middot;</span>
          )}
        </>
      ))}
    </div>
  </div>
)}