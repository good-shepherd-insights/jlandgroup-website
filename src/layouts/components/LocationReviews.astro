---
import ImageMod from "@/components/ImageMod.astro";
import DynamicIcon from "@/helpers/DynamicIcon";
import { markdownify } from "@/lib/utils/textConverter";

interface Props {
  city?: string;
  state?: string;
  gbp_url?: string;
  google_reviews_url?: string;
  yelp_url?: string;
  testimonials: {
    name: string;
    designation: string;
    avatar: string;
    content: string;
  }[];
}

const {
  city,
  state,
  gbp_url,
  google_reviews_url,
  yelp_url,
  testimonials,
} = Astro.props;

const hasReviewLinks = gbp_url || google_reviews_url || yelp_url;
const ctaUrl = google_reviews_url || gbp_url;
---

<section class="section bg-light">
  <div class="container">
    <div class="flex max-lg:flex-col max-lg:text-center gap-6 items-center mb-12 lg:mb-20">
      <div class="flex-2">
        <h2 class="h1 mb-6">
          {city && state
            ? `See what our clients in ${city} say`
            : "See what our clients say"}
        </h2>
        <p class="text-balance text-lg">
          We are proud of the trust we've built with our community. Here is what some of our satisfied customers have to say about our roofing and restoration services.
        </p>
      </div>

      {hasReviewLinks && (
        <div class="flex flex-wrap gap-4 max-lg:justify-center">
          {gbp_url && (
            <a
              href={gbp_url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 btn btn-outline border-primary text-primary hover:text-white"
            >
              <DynamicIcon icon="FaGoogle" className="text-sm" />
              See our reviews on Google
            </a>
          )}
          {yelp_url && (
            <a
              href={yelp_url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 btn btn-outline border-primary text-primary hover:text-white"
            >
              <DynamicIcon icon="FaYelp" className="text-sm" />
              See our reviews on Yelp
            </a>
          )}
        </div>
      )}
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        testimonials.map((item) => (
          <div class="rounded-2xl bg-body p-10 relative">
            <div class="flex items-center relative z-10">
              <div class="text-text-dark">
                <ImageMod
                  height={70}
                  width={70}
                  class="rounded-full"
                  src={item.avatar}
                  alt={item.name}
                  format="webp"
                />
              </div>
              <div class="ml-4">
                <h3 set:text={item.name} class="h6 font-primary font-semibold" />
                <p set:text={item.designation} class="text-text-dark/80" />
              </div>
            </div>
            <blockquote class="mt-8" set:html={markdownify(item.content)} />
          </div>
        ))
      }
    </div>

    {ctaUrl && (
      <div class="mt-12 text-center">
        <a
          href={ctaUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 btn btn-primary"
        >
          <DynamicIcon icon="FaPenToSquare" className="text-sm" />
          Leave us a review on Google
        </a>
      </div>
    )}
  </div>
</section>
