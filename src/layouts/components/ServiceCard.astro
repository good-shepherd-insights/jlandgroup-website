---
import ImageMod from "@/components/ImageMod.astro";
import { markdownify } from "@/lib/utils/textConverter";

// Import variations for A/B testing and design evolution
import Variation1 from "./designs/service-card/variation-1/ServiceCard.astro";
import Variation2 from "./designs/service-card/variation-2/ServiceCard.astro";
import Variation3 from "./designs/service-card/variation-3/ServiceCard.astro";

const { data, id, variant: forcedVariant } = Astro.props;

// Determine active variant (forced prop > A/B test hash > default)
// For A/B testing, we use a simple hash of the ID to ensure consistent experience per service
const getVariantFromId = (id: string) => {
  if (!id) return 0;
  let hash = 0;
  for (let i = 0; i < id.length; i++) {
    hash = id.charCodeAt(i) + ((hash << 5) - hash);
  }
  return Math.abs(hash % 4); // 0 = original, 1-3 = variations
};

const activeVariant = forcedVariant !== undefined ? forcedVariant : 3; // Default to Variation 3 per user request

// Map variants to components
const VariationMap: Record<number, any> = {
  1: Variation1,
  2: Variation2,
  3: Variation3,
};

const CurrentVariation = VariationMap[activeVariant];
---

{
  CurrentVariation ? (
    <CurrentVariation data={data} id={id} />
  ) : (
    <div
      class="border border-border rounded-xl p-8 flex gap-6"
    >
      {data.icon && (
        <img
          src={data.icon}
          alt={data.title}
          class="text-primary shrink-0 w-12 h-12"
          width="50"
          height="50"
        />
      )}
      <div class="h-full flex flex-col">
        <h3 class="h5 font-semibold mb-4" set:html={markdownify(data.title)} />
        <p class="mb-6 grow" set:html={markdownify(data.description)} />
        <a
          href={id ? `/services/${id}` : "#"}
          class="mt-auto inline-block text-text-dark/75 font-medium group"
        >
          Learn More
          <span class="inline-block transition-transform group-hover:translate-x-2 duration-300 text-xl ml-1">
            &rarr;
          </span>
        </a>
      </div>
    </div>
  )
}
